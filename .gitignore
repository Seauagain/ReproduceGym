# background / design notes, not version-controlled
docs/

# throwaway demos / probes, never committed
scratch/

# secrets — keep local only; never push to git remote, never ship to compute nodes
.env
.env.*
!.env.example

# real MetaX node inventory (hosts/keys) — local only; ship the .example template
/config/metax_nodes.yaml

# build artifacts / run outputs — keep the dir, ignore contents
/runs/*
!/runs/.gitkeep
# rollout flat-symlink views: build artifact, auto-created by reproducegym.dataset
/datasets/

# python
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.coverage
