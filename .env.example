# Copy to .env and fill in. .env is local-only: never committed, never shipped to compute nodes.
# All backends are cloud API calls; the pipeline needs no local model / GPU.
# A single GPUGeek-style gateway can serve all of them (Anthropic + OpenAI surfaces).

# ── Reproduction agent (Claude Code in sandbox) ──
# Launcher injects these standard names into the sandbox; the host pipeline's
# Claude calls reuse the same gateway. Anthropic surface => NO /v1 in base_url.
ANTHROPIC_BASE_URL=https://api.gpugeek.com/
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_OPUS_MODEL=Vendor2/Claude-4.6-opus
ANTHROPIC_DEFAULT_SONNET_MODEL=Vendor2/Claude-4.6-Sonnet
ANTHROPIC_DEFAULT_HAIKU_MODEL=Vendor2/Claude-4.5-Sonnet
CLAUDE_CODE_MAX_OUTPUT_TOKENS=128000
CLAUDE_CODE_MAX_TURNS=100
REPRODUCEGYM_PIPELINE_MODEL=Vendor2/Claude-4.6-Sonnet

# ── Multimodal vision: figure -> experimental evidence (OpenAI-compatible; OpenAI surface => /v1) ──
# Qwen-VL is one valid provider, but the code uses the generic MULTIMODAL_* names.
MULTIMODAL_API_KEY=
MULTIMODAL_BASE_URL=https://api.gpugeek.com/v1
MULTIMODAL_VISION_MODEL=Vendor3/qwen3-vl-32b-instruct
MULTIMODAL_MAX_TOKENS=16384

# ── MinerU: PDF -> Markdown + figures ──
# Used via the `mineru-open-api` CLI (pip install mineru-open-api), NOT a raw REST base_url.
# Batch (preferred): mineru-open-api extract <glob|--list f> -o <dir> --language en --model pipeline --timeout 1800
#   <=200 files/request, server-side concurrent. Don't loop single files; chunk with `split -l 200` if more.
MINERU_TOKEN=
MINERU_API_KEY=${MINERU_TOKEN}
