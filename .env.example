# Copy to .env and fill in. .env is local-only: never committed, never shipped to compute nodes.
# All three backends are cloud API calls; the pipeline needs no local model / GPU.

# ── MinerU: PDF → Markdown + figures (cloud API) ──
MINERU_API_KEY=
MINERU_BASE_URL=

# ── Qwen-VL: figure → experimental params / curve targets (OpenAI-compatible API) ──
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_VL_MODEL=qwen-vl-max

# ── Claude: claim reasoning + build-task agent (via relay; do NOT append /v1) ──
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://ai.prism.uno
